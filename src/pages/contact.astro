---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import Icon from '../components/Icon.astro';
import { site } from '../data/site';
import { faqs } from '../data/faqs';
import type { IconName } from '../lib/icons';

const methods: {
  icon: IconName;
  label: string;
  value: string;
  note: string;
  href: string;
  cta: string;
  external?: boolean;
}[] = [
  {
    icon: 'phone',
    label: 'Call or text',
    value: site.phone,
    note: 'The fastest way to reach us during delivery hours.',
    href: `tel:${site.phoneHref}`,
    cta: 'Call now',
  },
  {
    icon: 'mail',
    label: 'Email us',
    value: site.email,
    note: 'Questions about groups or events? We reply within a few hours.',
    href: `mailto:${site.email}`,
    cta: 'Send an email',
  },
  {
    icon: 'pin',
    label: 'Where we deliver',
    value: 'Based in Largo, FL',
    note: `${site.serviceArea}. Free local delivery and launch.`,
    href: '/book',
    cta: 'Check availability',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout
  title="Contact & FAQ"
  description="Reach rentaSkii by phone or email. We deliver jet skis across the Florida Gulf Coast in Seminole, Madeira Beach, and John's Pass. Answers to common rental questions."
>
  <script
    type="application/ld+json"
    is:inline
    slot="head"
    set:html={JSON.stringify(faqSchema)}
  />

  <PageHeader
    eyebrow="We're here to help"
    title="Get in touch"
    lead="Questions before you book? We're glad to help you pick a ski, plan a route, or sort out the details. Reach us whichever way is easiest."
  />

  <section class="section">
    <div class="container">
      <script is:inline>
        document.querySelectorAll('.method-link, .info-card a.btn').forEach((link) => {
          link.addEventListener('click', () => {
            if (typeof fbq !== 'function') return;
            const eventId = crypto.randomUUID();
            fbq('track', 'Lead', { content_name: link.textContent?.trim() || 'Contact' }, { eventID: eventId });
          });
        });
      </script>
      <div class="methods">
        {
          methods.map((m, i) => (
            <article class="method-card reveal" data-reveal-delay={i + 1}>
              <span class="method-icon"><Icon name={m.icon} size="1.4rem" /></span>
              <p class="method-label">{m.label}</p>
              <p class="method-value">{m.value}</p>
              <p class="method-note">{m.note}</p>
              <a
                href={m.href}
                class="link method-link"
                {...m.external ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
              >
                {m.cta} <Icon name="arrow-right" size="1rem" />
              </a>
            </article>
          ))
        }
      </div>

      <div class="info-row">
        <div class="info-card reveal">
          <h2 class="info-title"><Icon name="clock" size="1.2rem" /> Delivery hours</h2>
          <ul class="hours-list" role="list">
            {
              site.hours.map((h) => (
                <li>
                  <span>{h.days}</span>
                  <strong>{h.time}</strong>
                </li>
              ))
            }
          </ul>
          <p class="info-note">{site.hoursNote}</p>
        </div>

        <div class="info-card reveal" data-reveal-delay="1">
          <h2 class="info-title"><Icon name="map" size="1.2rem" /> How delivery works</h2>
          <p class="info-text">{site.delivery}</p>
          <a href="/book" class="btn btn-ghost">
            <Icon name="calendar" size="1.05rem" /> Book your delivery
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt" id="faq">
    <div class="container container-narrow">
      <div class="section-head center reveal">
        <p class="eyebrow center">Good to know</p>
        <h2>Frequently asked questions</h2>
      </div>
      <div class="faq-list reveal">
        {
          faqs.map((f) => (
            <details class="faq-item" name="faq">
              <summary>
                <span>{f.q}</span>
                <span class="faq-chevron" aria-hidden="true" />
              </summary>
              <div class="faq-answer">
                <p>{f.a}</p>
              </div>
            </details>
          ))
        }
      </div>
      <p class="faq-more reveal">
        Still have a question? <a href={`tel:${site.phoneHref}`} class="link">Give us a call</a>.
        We're happy to talk it through.
      </p>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <div class="contact-cta reveal">
        <div>
          <h2>Ready when you are</h2>
          <p class="lead">Book online in about a minute, or call and we'll set it up.</p>
        </div>
        <a href="/book" class="btn btn-primary btn-lg">
          Book your ride <Icon name="arrow-right" size="1.1rem" />
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .methods {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .method-card {
    display: flex;
    flex-direction: column;
    padding: 1.7rem;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    transition: transform var(--t), border-color var(--t);
  }
  .method-card:hover {
    transform: translateY(-4px);
    border-color: rgba(45, 212, 191, 0.35);
  }
  .method-icon {
    display: grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    border-radius: var(--r-sm);
    background: rgba(45, 212, 191, 0.12);
    color: var(--teal-bright);
    margin-bottom: 1.1rem;
  }
  .method-label {
    font-size: var(--fs-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-mute);
  }
  .method-value {
    margin-top: 0.3rem;
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
  }
  .method-note {
    margin-top: 0.5rem;
    font-size: var(--fs-sm);
    color: var(--text-dim);
  }
  .method-link {
    margin-top: 1.1rem;
  }

  .info-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    margin-top: 1.25rem;
  }
  .info-card {
    padding: 1.7rem;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
  }
  .info-title {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-size: 1.25rem;
  }
  .info-title :global(svg) {
    color: var(--teal);
  }
  .hours-list {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    margin: 1.1rem 0;
  }
  .hours-list li {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 0.7rem;
    border-bottom: 1px solid var(--line);
    font-size: var(--fs-sm);
  }
  .hours-list li:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  .hours-list span {
    color: var(--text-dim);
  }
  .hours-list strong {
    font-family: var(--font-display);
  }
  .info-note,
  .info-text {
    font-size: var(--fs-sm);
    color: var(--text-dim);
  }
  .info-text {
    margin: 1.1rem 0 1.4rem;
  }

  /* FAQ accordion */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .faq-item {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r);
    overflow: hidden;
  }
  .faq-item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.15rem 1.3rem;
    cursor: pointer;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--fs-base);
    list-style: none;
  }
  .faq-item summary::-webkit-details-marker {
    display: none;
  }
  .faq-item summary:hover {
    color: var(--teal-bright);
  }
  .faq-chevron {
    flex-shrink: 0;
    width: 0.62rem;
    height: 0.62rem;
    border-right: 2px solid var(--teal);
    border-bottom: 2px solid var(--teal);
    rotate: 45deg;
    transition: rotate var(--t);
  }
  .faq-item[open] .faq-chevron {
    rotate: 225deg;
  }
  .faq-answer {
    padding: 0 1.3rem 1.25rem;
    color: var(--text-dim);
    font-size: var(--fs-sm);
  }
  .faq-more {
    margin-top: 1.5rem;
    text-align: center;
    color: var(--text-dim);
    font-size: var(--fs-sm);
  }

  .contact-cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: clamp(1.8rem, 4vw, 2.6rem);
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-xl);
  }
  .contact-cta .lead {
    margin-top: 0.4rem;
  }

  @media (max-width: 820px) {
    .methods {
      grid-template-columns: 1fr;
    }
    .info-row {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 520px) {
    .contact-cta {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
