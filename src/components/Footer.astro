---
import { site } from '../data/site';
import Icon from './Icon.astro';

const year = new Date().getFullYear();

const exploreLinks = [
  { href: '/', label: 'Home' },
  { href: '/fleet', label: 'The Fleet' },
  { href: '/book', label: 'Book a Ride' },
  { href: '/#experiences', label: 'Experiences' },
  { href: '/contact', label: 'Contact & FAQ' },
];

const socials = [
  {
    label: 'Instagram',
    href: site.social.instagram,
    path: '<rect x="3" y="3" width="18" height="18" rx="5.5"/><circle cx="12" cy="12" r="4"/><circle cx="17.3" cy="6.7" r="1.15" fill="currentColor" stroke="none"/>',
  },
  {
    label: 'Facebook',
    href: site.social.facebook,
    path: '<path d="M14.2 8.7h2.6V5.4h-2.6c-2.2 0-3.9 1.8-3.9 4v2.1H7.7v3.3h2.6V22h3.4v-7.2h2.6l.5-3.3h-3.1V9.4c0-.4.3-.7.7-.7Z" fill="currentColor" stroke="none"/>',
  },
  {
    label: 'TikTok',
    href: site.social.tiktok,
    path: '<path d="M16.4 3h-3.2v12.6a2.7 2.7 0 1 1-2.7-2.7c.3 0 .6 0 .9.1V9.7a5.9 5.9 0 1 0 5 5.8V9.2a7.1 7.1 0 0 0 4 1.3V7.3a3.9 3.9 0 0 1-4-4Z" fill="currentColor" stroke="none"/>',
  },
];
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <a href="/" class="footer-logo" aria-label={`${site.name} home`}>
        <img src="/logo-mark.png" alt="" width="500" height="242" aria-hidden="true" />
        <span>renta<span class="footer-logo-accent">Skii</span></span>
      </a>
      <p class="footer-blurb">
        Premium jet ski rentals delivered across the {site.region}. Open water,
        dolphins, and sandbar afternoons. Your ski dropped in the water for you.
      </p>
      <div class="footer-socials">
        {
          socials.map((s) => (
            <a href={s.href} class="footer-social" aria-label={s.label} target="_blank" rel="noopener noreferrer">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true" set:html={s.path} />
            </a>
          ))
        }
      </div>
    </div>

    <nav class="footer-col" aria-label="Footer">
      <h3 class="footer-heading">Explore</h3>
      <ul role="list">
        {exploreLinks.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
      </ul>
    </nav>

    <div class="footer-col">
      <h3 class="footer-heading">Reach Us</h3>
      <address class="footer-contact">
        <p class="footer-contact-row">
          <Icon name="pin" size="1.05rem" />
          <span>
            Based in Largo, FL<br />
            {site.serviceArea}
          </span>
        </p>
        <p class="footer-contact-row">
          <Icon name="phone" size="1.05rem" />
          <a href={`tel:${site.phoneHref}`}>{site.phone}</a>
        </p>
        <p class="footer-contact-row">
          <Icon name="mail" size="1.05rem" />
          <a href={`mailto:${site.email}`}>{site.email}</a>
        </p>
      </address>
    </div>

    <div class="footer-col">
      <h3 class="footer-heading">Delivery Windows</h3>
      <ul role="list" class="footer-hours">
        {
          site.hours.map((h) => (
            <li>
              <span>{h.days}</span>
              <strong>{h.time}</strong>
            </li>
          ))
        }
      </ul>
      <p class="footer-hours-note">{site.hoursNote}</p>
    </div>
  </div>

  <div class="container footer-bar">
    <p>© {year} {site.legalName}. All rights reserved.</p>
    <p class="footer-fineprint">Rentals subject to weather, tides &amp; availability. Must be 18+ to operate.</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--ink-2);
    border-top: 1px solid var(--line);
    margin-top: auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.7fr 1fr 1.4fr 1.3fr;
    gap: 2.6rem;
    padding-block: clamp(3rem, 6vw, 4.5rem) 2.5rem;
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.35rem;
  }
  .footer-logo img {
    display: block;
    height: 2.1rem;
    width: auto;
    border-radius: 9px;
  }
  .footer-logo-accent {
    color: var(--teal-bright);
  }
  .footer-blurb {
    margin-top: 1rem;
    color: var(--text-dim);
    font-size: var(--fs-sm);
    max-width: 34ch;
  }

  .footer-socials {
    display: flex;
    gap: 0.6rem;
    margin-top: 1.3rem;
  }
  .footer-social {
    display: grid;
    place-items: center;
    width: 2.5rem;
    height: 2.5rem;
    border: 1px solid var(--line-2);
    border-radius: var(--r-sm);
    color: var(--text-dim);
    transition: color var(--t), border-color var(--t), background var(--t), transform var(--t);
  }
  .footer-social svg {
    width: 1.2rem;
    height: 1.2rem;
  }
  .footer-social:hover {
    color: var(--teal-bright);
    border-color: var(--teal);
    background: rgba(45, 212, 191, 0.1);
    transform: translateY(-2px);
  }

  .footer-heading {
    font-size: var(--fs-xs);
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-mute);
    margin-bottom: 1.1rem;
  }

  .footer-col ul {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .footer-col a {
    color: var(--text-dim);
    font-size: var(--fs-sm);
    transition: color var(--t);
  }
  .footer-col a:hover {
    color: var(--teal-bright);
  }

  .footer-contact {
    font-style: normal;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .footer-contact-row {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    color: var(--text-dim);
    font-size: var(--fs-sm);
  }
  .footer-contact-row :global(svg) {
    color: var(--teal);
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  .footer-hours {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .footer-hours li {
    display: flex;
    flex-direction: column;
    font-size: var(--fs-sm);
  }
  .footer-hours span {
    color: var(--text-mute);
  }
  .footer-hours strong {
    color: var(--text-dim);
    font-weight: 600;
  }
  .footer-hours-note {
    margin-top: 1rem;
    font-size: var(--fs-xs);
    color: var(--text-mute);
  }

  .footer-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    justify-content: space-between;
    align-items: center;
    padding-block: 1.5rem;
    border-top: 1px solid var(--line);
    font-size: var(--fs-xs);
    color: var(--text-mute);
  }

  @media (max-width: 860px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem 2.4rem;
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  /* ---------- revamped mobile footer (compact) ---------- */
  @media (max-width: 560px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 0;
      padding-block: 1.75rem 0.5rem;
    }

    /* brand becomes a centered intro block */
    .footer-brand {
      text-align: center;
      padding-bottom: 1rem;
    }
    .footer-logo {
      justify-content: center;
    }
    .footer-blurb {
      margin: 0.55rem auto 0;
      font-size: var(--fs-xs);
      max-width: 40ch;
    }
    .footer-socials {
      justify-content: center;
      margin-top: 0.85rem;
    }

    /* each section reads as its own divided block, kept tight */
    .footer-col {
      padding-block: 0.85rem;
      border-top: 1px solid var(--line);
    }
    .footer-heading {
      margin-bottom: 0.55rem;
    }

    /* explore links: compact two-up grid */
    nav.footer-col ul {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.45rem 1rem;
    }

    .footer-contact {
      gap: 0.5rem;
    }
    .footer-hours {
      gap: 0.4rem;
    }
    /* hours read as compact label→value rows instead of stacked pairs */
    .footer-hours li {
      flex-direction: row;
      justify-content: space-between;
      gap: 1rem;
    }
    .footer-hours-note {
      margin-top: 0.5rem;
    }

    /* tighten the bottom bar */
    .footer-bar {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 0.35rem;
      padding-block: 1rem;
    }
  }
</style>
