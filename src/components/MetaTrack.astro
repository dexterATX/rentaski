---
interface Props {
  event: string;
  eventId: string;
  customData?: Record<string, unknown>;
}

const { event, eventId, customData = {} } = Astro.props;
---

<script is:inline define:vars={{ event, eventId, customData }}>
  if (typeof fbq === 'function') {
    fbq('track', event, customData, { eventID: eventId });
  }
  // Mirror to CAPI via /api/track with the same eventID. metaBeacon (defined in
  // BaseLayout) reads _fbp/_fbc from cookies so the server event carries the
  // same browser identifiers as the pixel. On SSR pages the server may also
  // send CAPI with this eventID — Meta dedups both.
  if (typeof window.metaBeacon === 'function') {
    window.metaBeacon(event, eventId, customData);
  } else {
    try {
      navigator.sendBeacon(
        '/api/track',
        new Blob([JSON.stringify({ event, eventId, sourceUrl: location.href, customData })], {
          type: 'application/json',
        }),
      );
    } catch (_) { /* telemetry is best-effort */ }
  }
</script>