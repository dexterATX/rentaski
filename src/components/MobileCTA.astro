---
// Sticky bottom action bar — mobile only. A premium-commerce pattern: once the
// user scrolls past the hero, a persistent "Book" CTA stays within thumb reach.
// Hidden on >=720px and when the footer is in view (so it never covers it).
import { site } from '../data/site';
import Icon from './Icon.astro';
---

<div class="mobile-cta" data-mobile-cta aria-hidden="true">
  <a href={`tel:${site.phoneHref}`} class="mobile-cta-call" aria-label="Call us">
    <Icon name="phone" size="1.15rem" />
    <span>Call</span>
  </a>
  <a href="/book" class="mobile-cta-book">
    Book your ride
    <Icon name="arrow-right" size="1.05rem" />
  </a>
</div>

<script>
  const bar = document.querySelector<HTMLElement>('[data-mobile-cta]');
  if (bar) {
    // Show after the user scrolls roughly one viewport (past the hero).
    const footer = document.querySelector('.site-footer, footer');
    let footerVisible = false;

    if (footer) {
      const fo = new IntersectionObserver(
        (entries) => {
          footerVisible = entries[0].isIntersecting;
          update();
        },
        { rootMargin: '0px' },
      );
      fo.observe(footer);
    }

    const update = () => {
      const past = window.scrollY > window.innerHeight * 0.7;
      bar.classList.toggle('is-shown', past && !footerVisible);
      bar.setAttribute('aria-hidden', String(!(past && !footerVisible)));
    };

    let ticking = false;
    window.addEventListener(
      'scroll',
      () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          ticking = false;
          update();
        });
      },
      { passive: true },
    );
    update();
  }
</script>

<style>
  .mobile-cta {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 90;
    display: none;
    gap: 0.65rem;
    padding: 0.7rem var(--pad-x);
    padding-bottom: calc(0.7rem + env(safe-area-inset-bottom, 0px));
    background: color-mix(in srgb, var(--ink) 88%, transparent);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-top: 1px solid var(--line-2);
    transform: translateY(120%);
    transition: transform var(--t-slow);
  }
  .mobile-cta.is-shown {
    transform: none;
  }

  .mobile-cta-call {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.1rem;
    flex-shrink: 0;
    min-width: 3.6rem;
    padding: 0.5rem 0.7rem;
    border-radius: var(--r-sm);
    border: 1px solid var(--line-2);
    background: var(--surface-2);
    color: var(--text);
    font-size: 0.7rem;
    font-weight: 600;
  }
  .mobile-cta-call :global(svg) {
    color: var(--teal-bright);
  }

  .mobile-cta-book {
    flex: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.95rem 1.4rem;
    border-radius: var(--r-full);
    background: var(--grad-sun);
    color: #2a1206;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--fs-base);
    box-shadow: 0 10px 28px -12px rgba(255, 122, 69, 0.7);
  }

  /* phones only */
  @media (max-width: 720px) {
    .mobile-cta {
      display: flex;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-cta {
      transition: none;
    }
  }
</style>
