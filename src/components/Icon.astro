---
import { iconPaths, type IconName } from '../lib/icons';

interface Props {
  name: IconName;
  size?: number | string;
  class?: string;
}

const { name, size = '1.25em', class: className } = Astro.props;
const dim = typeof size === 'number' ? `${size}px` : size;
---

<svg
  class={className}
  width={dim}
  height={dim}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={iconPaths[name]}
></svg>
