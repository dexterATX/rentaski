# ----------------------------------------------------------------------------
# rentaSkii environment configuration
# Copy this file to ".env" and fill in your values.
# ----------------------------------------------------------------------------

# Stripe API keys — https://dashboard.stripe.com/apikeys
# Use TEST keys (sk_test_…) while developing. Card 4242 4242 4242 4242 works in test mode.
#
# IMPORTANT: until STRIPE_SECRET_KEY is set, the site runs in DEMO MODE — the
# booking flow works end to end (and now saves bookings + sends confirmation
# emails) but no real payment is taken. Add the key to switch on live Stripe.
STRIPE_SECRET_KEY=

# Stripe webhook signing secret — https://dashboard.stripe.com/webhooks
# Create a webhook pointing at https://yourdomain.com/api/webhook and listening
# for the "checkout.session.completed" event, then paste its signing secret here.
STRIPE_WEBHOOK_SECRET=

# Public absolute URL of the deployed site (no trailing slash).
PUBLIC_SITE_URL=https://rentaskii.com

# ----------------------------------------------------------------------------
# Confirmation email
# ----------------------------------------------------------------------------
# Sends the customer a booking confirmation and you a staff copy. Until a provider
# is configured, email runs in DEMO MODE — it logs what it *would* send instead of
# sending (bookings are still saved to data/bookings.jsonl either way).
#
# Provider is auto-selected: Resend if RESEND_API_KEY is set, else Gmail SMTP if
# SMTP_USER + SMTP_PASS are set, else demo mode.

# --- Option 1: Resend (recommended) -----------------------------------------
# Free: 3,000 emails/month. https://resend.com
#   1. Sign up, then create an API key → paste it here.
#   2. EMAIL_FROM: before you verify a domain, Resend only lets you send from
#      "onboarding@resend.dev" and only TO your own Resend account email. That's
#      enough to test. After you verify rentaskii.com in the Resend dashboard,
#      set EMAIL_FROM to an address on it (e.g. hello@rentaskii.com).
#   3. Test it:
#      RESEND_API_KEY=re_xxx EMAIL_TEST_TO=your_account_email node scripts/email-selftest.mjs
RESEND_API_KEY=

# From header for outbound mail. With Resend pre-verification, leave this blank
# (defaults to onboarding@resend.dev). After verifying a domain:
#   EMAIL_FROM="rentaSkii <hello@rentaskii.com>"
EMAIL_FROM=

# --- Option 2: Gmail SMTP (fallback) ----------------------------------------
# Free, ~500 emails/day. Requires an App Password (needs 2-Step Verification on).
#   https://myaccount.google.com/apppasswords  → choose "Mail" → 16-char code.
SMTP_USER=
SMTP_PASS=
# Legacy "From" override for SMTP (use EMAIL_FROM going forward).
SMTP_FROM=

# Optional address that receives the staff copy of every booking.
# Defaults to EMAIL_FROM / SMTP_USER. Set to route booking alerts elsewhere.
BOOKINGS_NOTIFY_EMAIL=

# ----------------------------------------------------------------------------
# Admin bookings view
# ----------------------------------------------------------------------------
# Token guarding /api/bookings. When unset, that endpoint is disabled (404).
ADMIN_TOKEN=
